{
  "info": {
    "name": "NNPTUDM Bt buoi4 — Roles & Users",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "roleId", "value": "r1" },
    { "key": "username", "value": "nguyenvana" }
  ],
  "item": [
    {
      "name": "Roles",
      "item": [
        {
          "name": "GET all roles",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/roles"
          }
        },
        {
          "name": "GET role by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/roles/{{roleId}}"
          }
        },
        {
          "name": "POST create role",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tester\",\n  \"description\": \"Role kiểm thử\"\n}"
            },
            "url": "{{baseUrl}}/roles"
          }
        },
        {
          "name": "PUT update role",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Quản trị viên\",\n  \"description\": \"Mô tả đã cập nhật\"\n}"
            },
            "url": "{{baseUrl}}/roles/{{roleId}}"
          }
        },
        {
          "name": "DELETE role",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/roles/{{roleId}}"
          }
        },
        {
          "name": "GET users in role",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/roles/{{roleId}}/users"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "GET all users",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "GET user by username",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/users/{{username}}"
          }
        },
        {
          "name": "POST create user (default role r1)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"longtest\",\n  \"password\": \"123456\",\n  \"email\": \"long@gmail.com\"\n}"
            },
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "POST create user (with roleId)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"user_moi\",\n  \"password\": \"123456\",\n  \"email\": \"moi@gmail.com\",\n  \"roleId\": \"r2\"\n}"
            },
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "PUT update user",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newmail@gmail.com\",\n  \"fullName\": \"Tên mới\",\n  \"roleId\": \"r3\"\n}"
            },
            "url": "{{baseUrl}}/users/{{username}}"
          }
        },
        {
          "name": "DELETE user",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/users/{{username}}"
          }
        }
      ]
    }
  ]
}
